# App UI
# -----------------------------
st.title("📈 Any Stock DCF Calculator")
st.write(
    "Type any stock ticker. The app pulls Yahoo Finance data, fills the model, and calculates enterprise value, "
    "equity value, implied share price, upside/downside, and valuation signal."
)

with st.expander("What the app calculates"):
    st.markdown(
        """
        **Enterprise Value** = PV of forecast free cash flows + PV of terminal value  
        **Equity Value** = Enterprise Value − Net Debt  
        **Implied Share Price** = Equity Value ÷ Shares Outstanding  
        **Upside / Downside** = Implied Share Price ÷ Current Price − 1  

        Signal rule:
        - More than **+10%** upside = **Undervalued**
        - More than **-10%** downside = **Overvalued**
        - Between those = **Fairly Valued**
        """
    )

ticker_symbol = st.text_input("Enter any stock ticker", value="AAPL").upper().strip()
calculate_button = st.button("Calculate DCF", type="primary")

st.sidebar.header("DCF Assumptions")
growth_rate = st.sidebar.number_input("Annual FCF growth rate", value=0.05, step=0.01, format="%.2f")
forecast_years = st.sidebar.slider("Forecast years", min_value=3, max_value=10, value=5)
wacc = st.sidebar.number_input("Discount rate / WACC", min_value=0.01, max_value=0.50, value=0.09, step=0.005, format="%.3f")
terminal_growth = st.sidebar.number_input("Terminal growth rate", min_value=-0.05, max_value=0.10, value=0.025, step=0.005, format="%.3f")

if calculate_button or ticker_symbol:
    if not ticker_symbol:
        st.warning("Please type a ticker.")
        st.stop()

    with st.spinner(f"Pulling Yahoo Finance data for {ticker_symbol}..."):
        info, cashflow, balance, income, history = load_yahoo(ticker_symbol)

    auto = build_auto_inputs(info, cashflow, balance, income, history)

    company_name = info.get("longName") or info.get("shortName") or ticker_symbol
    currency = info.get("financialCurrency") or info.get("currency") or "USD"

    st.subheader(f"{company_name} ({ticker_symbol})")
    st.caption(f"Currency: {currency} | Refreshed: {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}")

    st.sidebar.header("Auto-filled Yahoo Inputs")
    st.sidebar.caption("These start from Yahoo Finance. Edit them only if something looks wrong or missing.")

    base_fcf = st.sidebar.number_input(
        "Base free cash flow",
        value=safe_input_default(auto["free_cash_flow"]),
        step=100_000_000.0,
    )
    cash = st.sidebar.number_input(
        "Cash",
        value=safe_input_default(auto["cash"]),
        step=100_000_000.0,
    )
    debt = st.sidebar.number_input(
        "Debt",
        value=safe_input_default(auto["debt"]),
        step=100_000_000.0,
    )
    shares = st.sidebar.number_input(
        "Shares outstanding",
        value=safe_input_default(auto["shares"]),
        step=10_000_000.0,
    )
    current_price = st.sidebar.number_input(
        "Current share price",
        value=safe_input_default(auto["current_price"]),
        step=1.0,
    )

    missing = []
    if base_fcf <= 0:
        missing.append("positive free cash flow")
    if shares <= 0:
        missing.append("shares outstanding")
    if current_price <= 0:
        missing.append("current share price")
    if wacc <= terminal_growth:
        missing.append("WACC greater than terminal growth")

    if missing:
        st.error(
            "The app needs these inputs to calculate the DCF: "
            + ", ".join(missing)
            + ". Enter them in the sidebar and rerun."
        )
        st.stop()

    dcf = calculate_dcf(
        base_fcf=base_fcf,
        growth_rate=growth_rate,
        years=forecast_years,
        wacc=wacc,
        terminal_growth=terminal_growth,
        cash=cash,
        debt=debt,
        shares=shares,
        current_price=current_price,
    )

    col1, col2, col3, col4, col5 = st.columns(5)
    col1.metric("Enterprise Value", fmt_money(dcf["enterprise_value"]))
    col2.metric("Equity Value", fmt_money(dcf["equity_value"]))
    col3.metric("Implied Share Price", fmt_price(dcf["implied_share_price"]))
    col4.metric("Upside / Downside", fmt_pct(dcf["upside_downside"]))
    col5.metric("Signal", dcf["signal"])

    tab1, tab2, tab3, tab4 = st.tabs(["DCF Output", "Yahoo Data Used", "Forecast Table", "Teaching"])

    with tab1:
        summary = pd.DataFrame(
            {
                "Item": [
                    "Base free cash flow",
                    "PV of forecast FCF",
                    "Terminal value",
                    "PV of terminal value",
                    "Enterprise value",
                    "Cash",
                    "Debt",
                    "Net debt",
                    "Equity value",
                    "Shares outstanding",
                    "Current share price",
                    "Implied share price",
                    "Upside / downside",
                    "Signal",
                ],
                "Value": [
                    fmt_money(base_fcf),
                    fmt_money(sum(dcf["pv_fcfs"])),
                    fmt_money(dcf["terminal_value"]),
                    fmt_money(dcf["pv_terminal_value"]),
                    fmt_money(dcf["enterprise_value"]),
                    fmt_money(cash),
                    fmt_money(debt),
                    fmt_money(dcf["net_debt"]),
                    fmt_money(dcf["equity_value"]),
                    f"{shares:,.0f}",
                    fmt_price(current_price),
                    fmt_price(dcf["implied_share_price"]),
                    fmt_pct(dcf["upside_downside"]),
                    dcf["signal"],
                ],
            }
        )
        st.dataframe(summary, use_container_width=True, hide_index=True)

    with tab2:
        yahoo_df = pd.DataFrame(
            {
                "Yahoo Finance Field": [
                    "Current price",
                    "Market cap",
                    "Yahoo enterprise value",
                    "Shares outstanding",
                    "Cash",
                    "Debt",
                    "Operating cash flow",
                    "Capital expenditures",
                    "Free cash flow estimate",
                    "Revenue",
                    "EBIT",
                ],
                "Value Pulled": [
                    fmt_price(auto["current_price"]),
                    fmt_money(auto["market_cap"]),
                    fmt_money(auto["yahoo_enterprise_value"]),
                    "N/A" if auto["shares"] is None else f"{auto['shares']:,.0f}",
                    fmt_money(auto["cash"]),
                    fmt_money(auto["debt"]),
                    fmt_money(auto["operating_cash_flow"]),
                    fmt_money(auto["capex"]),
                    fmt_money(auto["free_cash_flow"]),
                    fmt_money(auto["revenue"]),
                    fmt_money(auto["ebit"]),
                ],
            }
        )
        st.dataframe(yahoo_df, use_container_width=True, hide_index=True)

    with tab3:
        forecast_df = pd.DataFrame(
            {
                "Year": [f"Year {i}" for i in range(1, forecast_years + 1)],
                "Projected FCF": [fmt_money(x) for x in dcf["projected_fcfs"]],
                "PV of FCF": [fmt_money(x) for x in dcf["pv_fcfs"]],
            }
        )
        st.dataframe(forecast_df, use_container_width=True, hide_index=True)

    with tab4:
        st.markdown(
            """
            ### How to read this DCF

            **1. Free cash flow**  
            The app estimates free cash flow from Yahoo Finance as:

            `Free Cash Flow = Operating Cash Flow + Capital Expenditures`

            **2. Enterprise value**  
            Enterprise value is the value of the operating business:

            `Enterprise Value = PV of Forecast FCF + PV of Terminal Value`

            **3. Equity value**  
            Equity value is what belongs to common shareholders:

            `Equity Value = Enterprise Value - Net Debt`

            **4. Implied share price**  
            The app divides equity value by shares outstanding:

            `Implied Share Price = Equity Value / Shares Outstanding`

            **5. Signal**  
            The model compares implied price to market price:
            - If implied price is more than 10% above market price: **undervalued**
            - If implied price is more than 10% below market price: **overvalued**
            - Otherwise: **fairly valued**
            """
        )

st.caption("Educational model only. Yahoo Finance / yfinance data may be missing, delayed, or inconsistent.")



# Any Stock DCF Calculator

Type any stock ticker and the Streamlit app pulls Yahoo Finance data through `yfinance`, then calculates:

- Enterprise value
- Equity value
- Implied share price
- Upside/downside
- Undervalued / overvalued / fairly valued signal

## Run locally

```bash
pip install -r requirements.txt
streamlit run app.py
```

