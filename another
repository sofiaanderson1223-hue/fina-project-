import math
from datetime import datetime

import numpy as np
import pandas as pd
import streamlit as st
import yfinance as yf


st.set_page_config(page_title="Any Stock DCF Calculator", page_icon="📈", layout="wide")


# -----------------------------
# Formatting / safety helpers
# -----------------------------
def to_float(value, default=None):
    try:
        if value is None:
            return default
        value = float(value)
        if math.isnan(value) or math.isinf(value):
            return default
        return value
    except Exception:
        return default


def safe_input_default(value, default=0.0):
    value = to_float(value, default)
    return default if value is None else float(value)


def fmt_money(value):
    value = to_float(value)
    if value is None:
        return "N/A"

    sign = "-" if value < 0 else ""
    value = abs(value)

    if value >= 1_000_000_000_000:
        return f"{sign}${value / 1_000_000_000_000:,.2f}T"
    if value >= 1_000_000_000:
        return f"{sign}${value / 1_000_000_000:,.2f}B"
    if value >= 1_000_000:
        return f"{sign}${value / 1_000_000:,.2f}M"
    return f"{sign}${value:,.0f}"


def fmt_price(value):
    value = to_float(value)
    if value is None:
        return "N/A"
    return f"${value:,.2f}"


def fmt_pct(value):
    value = to_float(value)
    if value is None:
        return "N/A"
    return f"{value:.1%}"


def get_info_number(info, possible_keys):
    for key in possible_keys:
        if key in info and info[key] is not None:
            value = to_float(info[key])
            if value is not None:
                return value
    return None


def get_statement_row(statement, possible_names):
    if statement is None or statement.empty:
        return None

    for name in possible_names:
        if name in statement.index:
            values = pd.to_numeric(statement.loc[name], errors="coerce").dropna()
            if len(values) > 0:
                return to_float(values.iloc[0])
    return None


# -----------------------------
# Yahoo Finance functions
# -----------------------------
@st.cache_data(ttl=900, show_spinner=False)
def load_yahoo(ticker_symbol):
    ticker_symbol = ticker_symbol.strip().upper()
    ticker = yf.Ticker(ticker_symbol)

    try:
        info = ticker.get_info()
    except Exception:
        try:
            info = ticker.info
        except Exception:
            info = {}

    try:
        cashflow = ticker.cashflow
    except Exception:
        cashflow = pd.DataFrame()

    try:
        balance = ticker.balance_sheet
    except Exception:
        balance = pd.DataFrame()

    try:
        income = ticker.financials
    except Exception:
        income = pd.DataFrame()

    try:
        history = ticker.history(period="5d", auto_adjust=False)
    except Exception:
        history = pd.DataFrame()

    return info or {}, cashflow, balance, income, history


def build_auto_inputs(info, cashflow, balance, income, history):
    current_price = get_info_number(info, ["currentPrice", "regularMarketPrice", "previousClose"])
    if current_price is None and history is not None and not history.empty and "Close" in history.columns:
        close = pd.to_numeric(history["Close"], errors="coerce").dropna()
        if len(close) > 0:
            current_price = to_float(close.iloc[-1])

    shares = get_info_number(info, ["sharesOutstanding", "impliedSharesOutstanding"])

    cash = get_info_number(info, ["totalCash", "cash"])
    if cash is None:
        cash = get_statement_row(
            balance,
            ["Cash And Cash Equivalents", "Cash Cash Equivalents And Short Term Investments", "Cash"],
        )

    debt = get_info_number(info, ["totalDebt"])
    if debt is None:
        current_debt = get_statement_row(balance, ["Current Debt", "Short Long Term Debt"]) or 0
        long_debt = get_statement_row(balance, ["Long Term Debt", "Long Term Debt And Capital Lease Obligation"]) or 0
        debt = current_debt + long_debt

    operating_cash_flow = get_statement_row(cashflow, ["Operating Cash Flow", "Total Cash From Operating Activities"])
    capex = get_statement_row(cashflow, ["Capital Expenditure", "Capital Expenditures"])

    if operating_cash_flow is not None and capex is not None:
        # yfinance usually reports capex as a negative number.
        free_cash_flow = operating_cash_flow + capex
    else:
        free_cash_flow = get_info_number(info, ["freeCashflow"])

    market_cap = get_info_number(info, ["marketCap"])
    yahoo_enterprise_value = get_info_number(info, ["enterpriseValue"])
    revenue = get_statement_row(income, ["Total Revenue"])
    ebit = get_statement_row(income, ["EBIT", "Operating Income"])

    return {
        "current_price": current_price,
        "shares": shares,
        "cash": cash,
        "debt": debt,
        "operating_cash_flow": operating_cash_flow,
        "capex": capex,
        "free_cash_flow": free_cash_flow,
        "market_cap": market_cap,
        "yahoo_enterprise_value": yahoo_enterprise_value,
        "revenue": revenue,
        "ebit": ebit,
    }


# -----------------------------
# DCF math
# -----------------------------
def calculate_dcf(base_fcf, growth_rate, years, wacc, terminal_growth, cash, debt, shares, current_price):
    projected_fcfs = []
    current_fcf = base_fcf

    for _ in range(years):
        current_fcf = current_fcf * (1 + growth_rate)
        projected_fcfs.append(current_fcf)

    pv_fcfs = []
    for i, fcf in enumerate(projected_fcfs, start=1):
        pv_fcfs.append(fcf / ((1 + wacc) ** i))

    terminal_value = projected_fcfs[-1] * (1 + terminal_growth) / (wacc - terminal_growth)
    pv_terminal_value = terminal_value / ((1 + wacc) ** years)

    enterprise_value = sum(pv_fcfs) + pv_terminal_value
    net_debt = debt - cash
    equity_value = enterprise_value - net_debt
    implied_share_price = equity_value / shares
    upside_downside = implied_share_price / current_price - 1

    if upside_downside > 0.10:
        signal = "UNDERVALUED"
    elif upside_downside < -0.10:
        signal = "OVERVALUED"
    else:
        signal = "FAIRLY VALUED"

    return {
        "projected_fcfs": projected_fcfs,
        "pv_fcfs": pv_fcfs,
        "terminal_value": terminal_value,
        "pv_terminal_value": pv_terminal_value,
        "enterprise_value": enterprise_value,
        "net_debt": net_debt,
        "equity_value": equity_value,
        "implied_share_price": implied_share_price,
        "upside_downside": upside_downside,
        "signal": signal,
    }


